---
layout: layouts/base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <p class="post-meta">{{ page.date | readableDate }}</p>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
  {% set previous = collections.posts | previousPost(page.url) %}
  {% set next = collections.posts | nextPost(page.url) %}
  {% if previous or next %}
    <nav class="post-nav" aria-label="Post navigation">
      {% if previous %}
        <a class="post-nav-link" href="{{ previous.url }}">
          <span>Previous</span>
          {{ previous.data.title }}
        </a>
      {% endif %}
      {% if next %}
        <a class="post-nav-link" href="{{ next.url }}">
          <span>Next</span>
          {{ next.data.title }}
        </a>
      {% endif %}
    </nav>
  {% endif %}
</article>
